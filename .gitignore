# ═══════════════════════════════════════
# Vyndex — .gitignore
# ═══════════════════════════════════════

# ── Dependencies ──
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Build Output ──
.next/
out/
build/
dist/

# ── Testing ──
coverage/

# ═══════════════════════════════════════
# SENSITIVE — NEVER COMMIT THESE
# ═══════════════════════════════════════
.env
.env.*
!.env.example
.env.local
.env.development
.env.production
.env.staging
*.env
*password*
*.password
secrets.txt
*.secret
*.key
*.credentials
*.pem

# ── Vercel ──
.vercel

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Debug Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Misc ──
*.log
.cache/

# ── Internal planning docs (not needed in public repo) ──
Hackathon_Master_Plan.md
